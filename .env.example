# Shared access code both travelers enter on the gate screen
TRIP_ACCESS_CODE=change-me

# Data backend: "memory" (placeholder data, no infra needed) | "supabase" (Phase 8)
DATA_BACKEND=memory

# --- Supabase backend (set DATA_BACKEND=supabase) ---
# SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# SUPABASE_SECRET_KEY=sb_secret_...   # the "secret" API key (Settings → API); server-only, bypasses RLS, never shipped to the browser
# (legacy projects: SUPABASE_SERVICE_KEY with the service_role JWT also works)
